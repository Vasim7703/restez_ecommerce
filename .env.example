# ════════════════════════════════════════════════════════════════
# RESTEZ — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only needed for server-side admin operations (never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── NextAuth ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your-random-32-byte-hex-secret
# In production, set this to your actual domain
NEXTAUTH_URL=http://localhost:3000

# ── Prisma / PostgreSQL (Supabase) ────────────────────────────────
# Dashboard → Project Settings → Database → Connection string (URI)
# Transaction Pooler (port 6543) — used at runtime
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct Connection (port 5432) — used only for migrations
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── Razorpay ──────────────────────────────────────────────────────
# https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── Site URL (used by sitemap, OG tags, etc.) ─────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
